# Drishyamitra Backend Environment Variables
# Copy this file as .env and fill in your own values:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

SECRET_KEY=drishyamitra-super-secret-key-change-in-production
DATABASE_URL=sqlite:///drishyamitra.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800
CHROMA_PERSIST_DIR=./chroma_data

# Groq API Key (required for AI Assistant)
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Email sharing (SMTP / Gmail App Passwords)
# For Gmail: Enable 2FA, then generate App Password at https://myaccount.google.com/apppasswords
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# WhatsApp sharing (Twilio API) — Optional
# Sign up free at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: Public tunnel URL for WhatsApp image attachments
PUBLIC_BASE_URL=
